# SMTP configuration for website enquiry forms.
# Copy this file to .env.local and fill in the values from the client's email host.

# Mailbox is on Microsoft 365 (Outlook), managed via GoDaddy.
SMTP_HOST=smtp.office365.com
# Microsoft 365 uses 587 with STARTTLS
SMTP_PORT=587
# The mailbox login — the full email address
SMTP_USER=info@hamptonfamilydentist.com
# App Password generated from the Microsoft account (see setup notes). NOT the normal login password.
SMTP_PASS=

# The "from" address shown on the email (often the same as SMTP_USER)
SMTP_FROM=info@hamptonfamilydentist.com
SMTP_FROM_NAME=Hampton Family Dental Website

# Where enquiry submissions are delivered
ENQUIRY_TO=info@hamptonfamilydentist.com
